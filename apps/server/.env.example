# 서버 환경변수 (실제 값은 .env 에 두고 커밋하지 않는다)
# 검증 스키마: src/core/config/env.validation.ts

NODE_ENV=development
PORT=4000
# CORS 허용 출처. 콤마(,)로 여러 개 지정 가능 (끝 슬래시 없이)
# 예: http://localhost:3000,https://www.bgs.io.kr
CLIENT_ORIGIN=http://localhost:3000

# Supabase (대시보드 > Project Settings > API Keys)
SUPABASE_URL=https://<project-ref>.supabase.co
# ⚠️ 서버 전용 secret key (sb_secret_...). 절대 클라이언트 노출·커밋 금지
SUPABASE_SECRET_KEY=
# (선택) 클라이언트/RLS 컨텍스트용 publishable key (sb_publishable_...)
SUPABASE_PUBLISHABLE_KEY=
